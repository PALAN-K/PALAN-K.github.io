{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":[" "],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\ud83d\ude80 PalanK AI \uc704\ud0a4\uc5d0 \uc624\uc2e0 \uac83\uc744 \ud658\uc601\ud569\ub2c8\ub2e4!","text":"<p>\ud314\ub780\ucf00\uc774(PalanK) \uc704\ud0a4\ub294 \ucf54\ub529\uc774\ub098 \uc5b4\ub824\uc6b4 IT \uc9c0\uc2dd\uc774 \uc5c6\uc5b4\ub3c4, \ub204\uad6c\ub098 \ub0b4 \uc77c\uc0c1\uacfc \uc0ac\uc5c5\uc5d0 AI\ub97c \uc811\ubaa9\ud560 \uc218 \uc788\ub3c4\ub85d \uc2e4\uc804 \uac00\uc774\ub4dc\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.</p>"},{"location":"#_1","title":"\ud83d\udcda \uc8fc\uc694 \uce74\ud14c\uace0\ub9ac \uc0b4\ud3b4\ubcf4\uae30","text":"<p>\uc6b0\uce21 \uc0c1\ub2e8 \uba54\ub274\uc640 \uc88c\uce21 \uc0ac\uc774\ub4dc\ubc14\ub97c \uc774\uc6a9\ud574 \uc6d0\ud558\ub294 \uc815\ubcf4\ub97c \uc27d\uac8c \ucc3e\uc544\ubcf4\uc138\uc694!</p> <ul> <li>\ud83c\udf71 \uc18c\uc0c1\uacf5\uc778 AI \ud301: \uc2dd\ub2f9 \uc0ac\uc7a5\ub2d8, \uc790\uc601\uc5c5\uc790\ubd84\ub4e4\uc744 \uc704\ud55c \ub9de\ucda4\ud615 AI \ud65c\uc6a9\ubc95 (\ub9ac\ubdf0 \uc790\ub3d9\ud654, \ub9c8\ucf00\ud305 \ubb38\uad6c \ub4f1)</li> <li>\ud83d\udee0 \uc5c5\ubb34 \uc790\ub3d9\ud654: \ud769\uc5b4\uc838 \uc788\ub294 \ubc18\ubcf5 \uc5c5\ubb34\ub97c \ud558\ub098\ub85c \ubaa8\uc73c\uace0 \uc790\ub3d9\ud654\ud558\ub294 \ubc29\ubc95</li> <li>\ud83d\udcfa \ud314\ub780\ucf00\uc774 \ucf58\ud150\uce20 \uc18c\uc2a4: \uc720\ud29c\ube0c \uc601\uc0c1\uc5d0\uc11c \ub2e4\ub8ec \ud504\ub86c\ud504\ud2b8 \uc6d0\ubb38\uacfc \uc2e4\uc2b5 \uc790\ub8cc</li> </ul> <p>\ud83d\udc49 \ud314\ub780\ucf00\uc774 \uc720\ud29c\ube0c \ucc44\ub110 \ubc14\ub85c\uac00\uae30</p>"},{"location":"%EC%86%8C%EC%83%81%EA%B3%B5%EC%9D%B8%20AI%20%ED%8C%81/%EB%A6%AC%EB%B7%B0_%EB%8B%B5%EA%B8%80_%EC%83%9D%EC%84%B1%EA%B8%B0/","title":"\ud83d\udcf1 1\ubd84 \ub9cc\uc5d0 \ub05d\ub098\ub294 \uc6b0\ub9ac \uac00\uac8c \ub9de\ucda4\ud615 '\ub9ac\ubdf0 \ub2f5\uae00 \uc790\ud310\uae30' \ub9cc\ub4e4\uae30","text":"<p>\uc0ac\uc7a5\ub2d8\ub4e4, \ub9e4\uc77c \ubc24 \uc7a5\uc0ac \ub9c8\uce58\uace0 \ubc30\ub2ec \uc571 \ub9ac\ubdf0\uc5d0 \ub2f5\uae00 \ub2e4\uc2dc\ub290\ub77c \ub9ce\uc774 \uc9c0\uce58\uc2dc\uc8e0? \uc88b\uc740 \ub9ac\ubdf0\ubd80\ud130 \uac04\ud639 \ub2ec\ub9ac\ub294 \uc544\uc26c\uc6b4 \ub9ac\ubdf0\uae4c\uc9c0, \uc77c\uc77c\uc774 \uc815\uc131 \ub4e4\uc5ec \ub2ec\uc790\ub2c8 \ub108\ubb34 \ud53c\uace4\ud558\uace0, \ubcf5\uc0ac\ud574\uc11c \ubd99\uc5ec\ub123\uc790\ub2c8 \uc190\ub2d8\ub4e4\uc774 \uc11c\uc6b4\ud574\ud558\uc2e4\uae4c \ub178\uc2ec\ucd08\uc0ac\ud558\uc2dc\ub9ac\ub77c \uc0dd\uac01\ud569\ub2c8\ub2e4.</p> <p>\uc624\ub298\uc740 \ucf54\ub529\uc758 '\ucf54'\uc790\ub3c4 \ubab0\ub77c\ub3c4 \uc2a4\ub9c8\ud2b8\ud3f0 \ud558\ub098\ub85c \uad6c\uae00 \uc81c\ubbf8\ub098\uc774(Gemini)\ub97c \uc774\uc6a9\ud574 1\ubd84 \ub9cc\uc5d0 '\ub9ac\ubdf0 \ub2f5\uae00 \uc790\ud310\uae30'\ub97c \ub9cc\ub4dc\ub294 \ubc95\uc744 \uc54c\ub824\ub4dc\ub9bd\ub2c8\ub2e4. </p>"},{"location":"%EC%86%8C%EC%83%81%EA%B3%B5%EC%9D%B8%20AI%20%ED%8C%81/%EB%A6%AC%EB%B7%B0_%EB%8B%B5%EA%B8%80_%EC%83%9D%EC%84%B1%EA%B8%B0/#1_1","title":"1. \uc81c\ubbf8\ub098\uc774 \uce94\ubc84\uc2a4\ub85c \ub9cc\ub4e4\uae30","text":"<p>\uc2a4\ub9c8\ud2b8\ud3f0\uc774\ub098 PC\uc5d0\uc11c \uad6c\uae00 \uc81c\ubbf8\ub098\uc774\uc5d0 \uc811\uc18d\ud569\ub2c8\ub2e4. \ubaa8\ub378\uc740 'Gemini Advanced'\ub97c \uc120\ud0dd\ud558\uace0, \uce94\ubc84\uc2a4(Canvas) \uae30\ub2a5\uc744 \ucf1c\uc8fc\uc138\uc694. \uadf8\ub9ac\uace0 \uc544\ub798\uc758 \ud504\ub86c\ud504\ud2b8(\uba85\ub839\uc5b4)\ub97c \uadf8\ub300\ub85c \ubcf5\uc0ac\ud574\uc11c \ucc44\ud305\ucc3d\uc5d0 \ubd99\uc5ec\ub123\uae30\ub9cc \ud558\uba74 \ub429\ub2c8\ub2e4.</p> <p>\ud83d\udca1 \uc0ac\uc6a9\ub41c \ud504\ub86c\ud504\ud2b8 (\uadf8\ub300\ub85c \ubcf5\uc0ac\ud574\uc11c \uc0ac\uc6a9\ud558\uc138\uc694!) <code>\uc2dd\ub2f9 \uc0ac\uc7a5\ub2d8\uc774 \uc190\ub2d8 \ub9ac\ubdf0\ub97c \ubcf5\uc0ac\ud574 \ub123\uc73c\uba74, \uce5c\uc808\ud558\uace0 \uc13c\uc2a4 \uc788\ub294 \ub9de\ucda4\ud615 \ub2f5\uae00\uc744 \uc368\uc8fc\ub294 \uc6f9 \ud654\uba74\uc744 \ub9cc\ub4e4\uc5b4\uc918.</code></p> <p>\ub9c8\ubc95\ucc98\ub7fc AI\uac00 \uc2a4\uc2a4\ub85c \ucf54\ub529\ud558\uc5ec \ub098\ub9cc\uc758 '\uc13c\uc2a4 \ub9cc\uc810 \ub9ac\ubdf0 \ub2f5\uae00 \uc0dd\uc131\uae30'\ub97c \ub69d\ub531 \uc870\ub9bd\ud574 \uc90d\ub2c8\ub2e4. </p>"},{"location":"%EC%86%8C%EC%83%81%EA%B3%B5%EC%9D%B8%20AI%20%ED%8C%81/%EB%A6%AC%EB%B7%B0_%EB%8B%B5%EA%B8%80_%EC%83%9D%EC%84%B1%EA%B8%B0/#2","title":"2. \uc774\ub807\uac8c \uc0ac\uc6a9\ud574 \ubcf4\uc138\uc694!","text":"<p>\uc644\uc131\ub41c \ub9ac\ubdf0 \ub2f5\uae00 \uc0dd\uc131\uae30\uc5d0 \uc6b0\ub9ac \uc2dd\ub2f9 \uc774\ub984\uacfc \uc190\ub2d8\uc758 \ucc10 \ub9ac\ubdf0\ub97c \uadf8\ub300\ub85c \ubcf5\uc0ac\ud574\uc11c \ubd99\uc5ec\ub123\uc2b5\ub2c8\ub2e4.</p> <p>\uc190\ub2d8 \ub9ac\ubdf0 \uc608\uc2dc:</p> <p>\"\ub108\ubb34 \ub9db\uc788\uc5b4\uc694 \uc798 \uba39\uc5c8\uc5b4\uc694 \uc0ac\uc9c4\uc744 \ubabb\ucc0d\uc5c8\uc5b4\uc694.\"</p> <p>\uc120\ud0dd \uac00\ub2a5\ud55c \ubd84\uc704\uae30:  - \uce5c\uc808\ud558\uace0 \ub2e4\uc815\ud55c - \uaca9\uc2dd \uc788\uace0 \uc815\uc911\ud55c - \uc704\ud2b8 \uc788\uace0 \uc720\ucf8c\ud55c (\ud83d\udc48 \ud130\uce58!) - \uc9c4\uc9c0\ud558\uace0 \uacb8\uc190\ud55c </p> <p>\uacb0\uacfc\ubb3c:</p> <p>\"\uc544\uace0! \uc0ac\uc9c4 \ucc0d\uae30\ub3c4 \uc804\uc5d0 \uc813\uac00\ub77d\uc774 \uba3c\uc800 \ub9c8\uc911 \ub098\uac08 \ub9cc\ud07c \ub9db\uc788\uc73c\uc168\ub358 \uac8c \ubd84\uba85\ud558\ub124\uc694! \ub2e4\uc74c\uc5d4 \uce74\uba54\ub77c \ucf24 \uc2dc\uac04 3\ucd08\ub9cc \ub531 \ucc38\uace0 \uae30\ub2e4\ub824 \ub4dc\ub9b4 \ud14c\ub2c8, \uc870\ub9cc\uac04 \uaf2d \ub2e4\uc2dc \ub4e4\ub7ec\uc8fc\uc138\uc694! \uae30\ub2e4\ub9ac\uace0 \uc788\uc744\uac8c\uc694!\"</p> <p>\ub2e8\uc21c\ud55c \ub85c\ubd07 \uac19\uc740 \ub2f5\ubcc0\uc774 \uc544\ub2cc, 100\uc810\uc9dc\ub9ac \ub2e8\uace8 \uba54\uc774\ucee4 \ub2f5\ubcc0\uc774 \uc644\uc131\ub429\ub2c8\ub2e4!</p>"},{"location":"%EC%86%8C%EC%83%81%EA%B3%B5%EC%9D%B8%20AI%20%ED%8C%81/%EB%A6%AC%EB%B7%B0_%EB%8B%B5%EA%B8%80_%EC%83%9D%EC%84%B1%EA%B8%B0/#3","title":"3. \uc54c\ubc14\uc0dd\uacfc \uacf5\uc720\ud558\uae30","text":"<p>\uc644\uc131\ub41c \uc571\uc740 \ub9c1\ud06c\ub85c \ub9cc\ub4e4\uc5b4\uc11c \uc9c1\uc6d0\ub4e4\uc774\ub098 \uc54c\ubc14\uc0dd\uacfc \uacf5\uc720\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub0b4\uac00 \uc5c6\uc5b4\ub3c4, \ub9e4\uc7a5 \uc2dd\uad6c \ub204\uad6c\ub098 \ub611\uac19\uc740 \uace0\ud004\ub9ac\ud2f0\uc758 \uc0ac\uc7a5\ub2d8 \ud45c \ub2f5\uae00\uc744 \uc791\uc131\ud560 \uc218 \uc788\uac8c \ub429\ub2c8\ub2e4.</p> <p>\ud83d\udc49 \uc624\ub298 \uc601\uc0c1\uc5d0\uc11c \ub9cc\ub4e0 \ub9ac\ubdf0 \ub2f5\uae00 \uc0dd\uc131\uae30 \uc9c1\uc811 \uc368\ubcf4\uae30</p> <p>\ubb34\ub8cc AI \ube44\uc11c\ub97c \ucc44\uc6a9\ud558\uc2dc\uace0, \uace0\uac1d\uc744 \uac10\ub3d9\uc2dc\ud0a4\ub294 \ub2f5\uae00\ub85c \ub9e4\ucd9c\uacfc \ub2e8\uace8 \ub450 \ub9c8\ub9ac \ud1a0\ub07c\ub97c \ubaa8\ub450 \uc7a1\uc73c\uc138\uc694! \ub354 \ub9ce\uc740 \uc2e4\uc804 AI \ud65c\uc6a9\ubc95\uc774 \uad81\uae08\ud558\uc2dc\ub2e4\uba74 \uc720\ud29c\ube0c \ud314\ub780\ucf00\uc774 \ucc44\ub110\uc744 \ucc3e\uc544\uc8fc\uc138\uc694!</p>"}]}